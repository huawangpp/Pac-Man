rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'highScore']) &&
             data.keys().size() <= 4 &&
             data.displayName is string &&
             data.displayName.size() >= 1 &&
             data.displayName.size() <= 50 &&
             data.highScore is number &&
             data.highScore >= 0 &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!data.keys().hasAny(['lastPlayed']) || (data.lastPlayed is timestamp));
    }

    function isValidHighScore(data) {
      return data.keys().hasAll(['userId', 'displayName', 'score', 'timestamp', 'stage']) &&
             data.keys().size() == 5 &&
             data.userId == request.auth.uid &&
             data.displayName is string &&
             data.displayName.size() <= 50 &&
             data.score is number &&
             data.score >= 0 &&
             data.stage is number &&
             data.timestamp == request.time;
    }

    // Collection: Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.highScore > 0;
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update profile or score
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'highScore', 'lastPlayed'])
      );
    }

    // Collection: HighScores
    match /highScores/{scoreId} {
      allow read: if true; // Public leaderboard
      
      allow create: if isSignedIn() && isValidId(scoreId) && isValidHighScore(incoming());
      
      // High scores are immutable
      allow update, delete: if false;
    }
  }
}
